# Copy to .env and fill in values. Never commit .env to source control.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentflow
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=agentflow_docs
QDRANT_API_KEY=

# Required — every agent LLM call goes through Groq.
GROQ_API_KEY=

# Optional — real web search. Leave empty and keep USE_MOCK_SEARCH=true to use mock results.
TAVILY_API_KEY=

# Mock toggles. Set to false to use the real service.
USE_MOCK_SQL=false
USE_MOCK_VECTOR_SEARCH=false
USE_MOCK_SEARCH=true

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentflow-ai
LANGSMITH_TRACING=false
